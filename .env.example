# ── VioQuiz Environment Configuration ──────────────────────────────────────
# Copy this file to .env and fill in your values

# Server
PORT=3000

# MySQL Database (optional – app works without it using JSON fallback)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=vioquiz

# For Railway/Render deployment, use their provided DATABASE_URL or individual vars
# DB_HOST=mysql.railway.app
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=xxxx
# DB_NAME=railway
